{
  "manifest_version": 3,
  "name": "NoVig \u2014 Polymarket Edge Calculator",
  "version": "2.0.0",
  "description": "Find mispriced markets on Polymarket using no-vig probability from sharp sportsbooks.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}